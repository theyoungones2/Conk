#define HSPACE 4
#define VSPACE 2

static struct Gadget			*glist;
static void								*vi;
static struct TextAttr		*textattr;

static void SussOutGadgets( struct Window *win, struct ReqCrap *rc, UWORD count );
static UWORD CalcReqHeight( struct ReqCrap *rc, UWORD count, struct TextFont *tf );
static UWORD CalcReqWidth( struct ReqCrap *rc, UWORD count, struct TextFont *tf );
static UWORD CalcMaxLabel( struct ReqCrap *rc, UWORD count, struct TextFont *tf );
