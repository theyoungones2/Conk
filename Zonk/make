.key nam
Clear
IF  "all" EQ <nam>
 sc WITH SCOPTIONS Source/#?.c
; sc WITH SCOPTIONS Source/rexx/#?.c
ENDIF

IF "recomp" EQ <nam>
 sc WITH SCOPTIONS NOMOD Source/#?.c
; sc WITH SCOPTIONS NOMOD Source/rexx/#?.c
ENDIF

IF  "asm" EQ <nam>
 genam  Source/Wibble.s TO Code/Wibble.o WITH Genam.opts
ENDIF

IF  "gst" EQ <nam>
 sc makegst source/include/includes.gst source/include/includes.h
ENDIF
